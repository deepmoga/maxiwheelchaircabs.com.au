RewriteEngine On
RewriteBase /

# Remove .php extension
RewriteCond %{THE_REQUEST} /([^.]+)\.php [NC]
RewriteRule ^ %1 [R=301,L,NC]

# Serve existing files/directories as-is
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Service single pages
RewriteRule ^service/([a-zA-Z0-9_-]+)/?$ service.php?slug=$1 [L,QSA]

# Page routing
RewriteRule ^about/?$ about.php [L]
RewriteRule ^contact/?$ contact.php [L]
RewriteRule ^services/?$ services.php [L]
RewriteRule ^privacy-policy/?$ page.php?slug=privacy-policy [L]
RewriteRule ^terms-conditions/?$ page.php?slug=terms-conditions [L]

# Add .php extension internally
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^ %{REQUEST_URI}.php [L]
